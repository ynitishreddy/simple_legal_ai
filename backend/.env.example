# ─── Database ────────────────────────────────────────────────────────────────
# For local development SQLite is used automatically (legal_timeline.db).
# Set this to a PostgreSQL DSN for production:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/legal_timeline
DATABASE_URL=sqlite:///./legal_timeline.db

# ─── AWS / S3 ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET=indian-high-court-judgments
S3_PREFIX=raw/

# ─── App Settings ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
